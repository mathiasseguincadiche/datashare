# ──────────────────────────────────────────────
# DataShare — Backend (.env)
# Copier ce fichier : cp .env.example .env
# ──────────────────────────────────────────────

# ── Base de données PostgreSQL ──
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=datashare
DATABASE_USER=datashare_user
DATABASE_PASSWORD=datashare_password

# ── Authentification JWT ──
JWT_SECRET=change_me_en_production_min_32_caracteres

# ── Serveur ──
PORT=3000
NODE_ENV=development

# ── Stockage des fichiers ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=1073741824

# ── Frontend (CORS) ──
FRONTEND_URL=http://localhost:5173
